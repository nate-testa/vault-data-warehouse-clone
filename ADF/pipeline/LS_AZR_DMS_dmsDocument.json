								}
							},
							{
								"source": {
									"name": "create_ts",
									"type": "DateTime",
									"physicalType": "datetime"
								},
								"sink": {
									"name": "create_ts",
									"type": "DateTime",
									"physicalType": "datetime"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "Source_DMS_dmsDocument",
						"type": "DatasetReference"
					}
				],
				"outputs": [
