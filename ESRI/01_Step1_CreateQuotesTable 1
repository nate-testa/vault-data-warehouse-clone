	IF @update_cte_quote_esri_v2 = 1 BEGIN TRANSACTION BEGIN
		
		DROP TABLE IF EXISTS edw_cat_model.cte_ho_quote_esri_v2;
	
		with 
		esri_new as 
		(
			SELECT distinct
				   b.inforce_dt , 
				   product_nm, 
				   source_system, 
				   underwriter, 
				   created_by , 
				   referred_by , 
				   reviewed_by ,
				   case when quote_no like '%-%' then 'Renewal' else 'New Business' end quote_term,		-- is this accuracte?
	--			   original_policy_no , 																-- matches base_quote_no 
	--			   original_policy_effective_dt,			-- don't trust yet
				   b.base_prior_policy_no,
				   prior_policy_no,
				   base_quote_no, 
				   quote_no, 
				   program_type, 
				   quote_status, 
				   quote_calc_status as quote_status_calc,
				   quote_source_status as quote_status_source,
				   transaction_status,
	--			   latest_transaction_in,
				   transaction_seq_no,
				   transaction_desc ,
				   note_approval_or_denial,
				   note_not_taken_reason,
				   close_reason_desc as close_reason,	-- new field
				   quote_create as created_dt,
				   days_since_created, 
				   effective_dt effective_dt , 
				   expiration_dt expiration_dt , 
				   insured_name as customer_name, 
				   vip_in as customer_vip, 
				   address1, 
				   address2, 
				   city, 
				   state,
				   zip, 
				   county, 
				   0 as fips, 					-- calculate
				   region, 
				   latitude, 
				   longitude,
				   covA, 
				   covB, 
				   covC, 
				   covD, 
				   TIV, 
				   round(annual_premium_amt,0) as premium, 
				   round(ROL,4) ROL,
				   0 as TIV_expiring, 			-- calculate
				   0 as premium_expiring, 		-- calculate
				   0 as ROL_expiring, 			-- calculate
				   0 as aop__ded, 				-- calculate
				   0 as hu_ded, 				-- calculate
				   0 as wh_ded, 				-- calculate
				   0 as wf_ded, 				-- calculate
				   0 as wtr_ded, 				-- calculate
				   0 as aop_ded$, 				-- calculate
				   0 as hu_ded$, 				-- calculate
				   0 as wh_ded$, 				-- calculate
				   0 as wf_ded$, 				-- calculate
				   0 as wtr_ded$, 				-- calculate
				   'tbd' as aop_ded_sort, 			-- calculate
				   'tbd' as hu_ded_sort, 			-- calculate
				   'no' as exclude_wind,			-- calculate
				   'tbd' as exclude_water,			-- calculate
				   'tbd' as water_limit,			-- calculate
				   'tbd' as ded_largeLossWaiver,	-- calculate
				   'tbd' as construction_type, 		-- calculate
				   'tbd' as occupancy, 				-- calculate
				   'tbd' as dwelling_type,			-- calculate
				   0 as year_built,					-- calculate
				   0 as year_roof,					-- calculate
				   0 as total_st_ft,				-- calculate
				   i.inspection_status, 
				   inspection_completed_dt,	
				   (select max(inspection_update_dt) from edw_cat_model.Insp_Combined ic) as inspection_update_dt, 	
				   'tbd' as wildfire_score,
				   0 as aon_hurricane_aal_amt,								-- calculate
				   0 as aon_hurricane_cat_score_amt,						-- calculate
				   0 as aon_hurricane_cat_score_to_premium_ratio,			-- calculate
				   0 as aon_hurricane_aal_to_premium_ratio,					-- calculate
				   'tbd' as cape_roof_condition_rating,						-- calculate
				   0 as cape_roof_condition_rating_confidence,				-- calculate
				   '2024-04-21' as cape_roof_condition_rating_date,			-- calculate
				   'tbd' as cape_roof_condition_reasons,					-- calculate
				   agency_id, 
				   agency_lu, 
				   agency_state, 
				   case when home_policy_credit_in = 'yes' then 1 else 0 end as pif_ho, 			-- fix/validate
				   case when auto_policy_credit_in = 'yes' then 1 else 0 end as pif_au, 			-- fix/validate
				   case when collection_policy_credit_in = 'yes' then 1 else 0 end as pif_pel, 		-- fix/validate
				   case when excess_liability_policy_credit_in = 'yes' then 1 else 0 end as pif_lux,-- fix/validate
				   'hello' as dummy_string_1,
				   'hello' as dummy_string_2,
				   'hello' as dummy_string_3,
				   0 as dummy_number_1,
				   0 as dummy_number_2,
				   0 as dummy_number_3
			FROM vault_edw.edw_cat_model.cte_ho_quote_base b
			LEFT JOIN edw_cat_model.Insp_Combined i on b.base_quote_no = i.base_policy_no 
			WHERE 1=1
			 and product_nm IN('Homeowners','Condo')
			 and address1 is not null 
			 and case when quote_calc_status <> 'Declined' and days_since_created > 150  then 1 
	--				   when coalesce(latest_transaction_in,'y') = 'n' then 1 
	--				   when case when transaction_status = 'revised' coalesce(latest_transaction_in,'y') = 'n' then 1 
					   else 0 end = 0
		),
		quotes_to_policies as 
		(
			select distinct
				 coalesce(b.policy_no, bp.policy_no) policy_no , 
				 COALESCE(b.policy_status , bp.policy_status) policy_status, 
				 COALESCE(b.term_no , bp.term_no) policy_term_no, 
				 case when q.quote_no not like '%-%' then 0 else cast(right(q.quote_no, len(q.quote_no) - CHARINDEX('-', q.quote_no + '-')) as int) end quote_term_no, q.*
			from edw_cat_model.cte_all_quote q
			LEFT JOIN edw_cat_model.cte_ho_pif_base  b on b.base_policy_no  = q.base_quote_no 
			LEFT JOIN edw_cat_model.cte_ho_pif_base bp on bp.base_policy_no = q.base_prior 	  and b.base_policy_no is null
			where 1=1 
	--			and (case when b.policy_no is not null then case when max_quote_no is null then 0 else 1 end 
	--				  else 1 end) = 1
		),
		quotes_to_remove as 
		(
			select *
			from quotes_to_policies
			where 1=1
			and coalesce(policy_term_no,-1) >= quote_term_no
		),
		quotes as 
		(
			select e.*
			from esri_new e
			left join quotes_to_remove q on e.quote_no = q.quote_no 
			where 1=1
			and q.quote_no is null 
		)
			select *
			INTO edw_cat_model.cte_ho_quote_esri_v2
			from quotes
			where 1=1
			order by 2 desc
			
	END;		
	COMMIT;
	



